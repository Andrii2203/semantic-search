{
  "name": "semantic-search-engine",
  "version": "1.0.0",
  "description": "Universal semantic search engine with pluggable sources, profile-based filtering, and action dispatching",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
    "test:smoke": "jest --config jest.smoke.config.js --no-coverage",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"__tests__/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"__tests__/**/*.js\""
  },
  "keywords": [
    "semantic-search",
    "embeddings",
    "nlp",
    "content-discovery"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2"
  }
}
