# ============================================
# Semantic Search Engine — Environment Config
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Relative path from project root
DB_PATH=./data/app.db

# --- Groq LLM API ---
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_MAX_TOKENS=512

# --- Profiles ---
# Available: content, job_hunter
ACTIVE_PROFILE=content

# --- Search Engine ---
# Minimum cosine similarity score (0.0 — 1.0)
SIMILARITY_THRESHOLD=0.35

# --- Reddit ---
# Comma-separated subreddit names to fetch from
REDDIT_SUBREDDITS=programming,technology,webdev
# Max posts to fetch per cycle
REDDIT_LIMIT=50

# --- Scheduler ---
# Cron expression for fetch cycle (default: every 30 min)
CRON_SCHEDULE=*/30 * * * *

# --- Rate Limiting ---
# Max Groq API calls per minute
GROQ_RATE_LIMIT=10
# Max API requests per minute per IP
API_RATE_LIMIT=60

# --- CORS ---
# Comma-separated origins allowed to access the API
CORS_ORIGIN=http://localhost:3000

# --- Logging ---
# pino log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Djinni settings
DJINNI_KEYWORDS=JavaScript,Front-End
DJINNI_LIMIT=130
